<%- include('partials/header') %>

<h2 class="mb-4">
    Task Management
</h2>

<div class="custom-card">

    <h4 class="mb-4">
        Create Task
    </h4>

    <form action="/tasks/create" method="POST">

        <div class="row">

            <div class="col-md-6 mb-3">
                <input
                    type="text"
                    name="title"
                    class="form-control"
                    placeholder="Task Title"
                    required
                >
            </div>

            <div class="col-md-6 mb-3">
                <input
                    type="date"
                    name="dueDate"
                    class="form-control"
                >
            </div>

        </div>

        <div class="mb-3">
            <textarea
                name="description"
                class="form-control"
                rows="4"
                placeholder="Task Description"
            ></textarea>
        </div>

        <div class="row">

            <div class="col-md-6 mb-3">

                <select
                    name="assignedTo"
                    class="form-select"
                >

                    <% users.forEach(user => { %>

                        <option value="<%= user._id %>">
                            <%= user.name %>
                        </option>

                    <% }) %>

                </select>

            </div>

            <div class="col-md-6 mb-3">

                <select
                    name="project"
                    class="form-select"
                >

                    <% projects.forEach(project => { %>

                        <option value="<%= project._id %>">
                            <%= project.projectName %>
                        </option>

                    <% }) %>

                </select>

            </div>

        </div>

        <button class="btn btn-primary">
            Create Task
        </button>

    </form>

</div>

<div class="row">

<% tasks.forEach(task => { %>

    <div class="col-md-4">

        <div class="custom-card">

            <h4>
                <%= task.title %>
            </h4>

            <p>
                <%= task.description %>
            </p>

            <p>
                Assigned:
                <strong>
                    <%= task.assignedTo.name %>
                </strong>
            </p>

            <p>
                Due:
                <%= new Date(task.dueDate).toDateString() %>
            </p>

            <p>

                Status:

                <% if(task.status === "Pending") { %>

                    <span class="status-pending">
                        Pending
                    </span>

                <% } %>

                <% if(task.status === "In Progress") { %>

                    <span class="status-progress">
                        In Progress
                    </span>

                <% } %>

                <% if(task.status === "Completed") { %>

                    <span class="status-completed">
                        Completed
                    </span>

                <% } %>

            </p>

            <form action="/tasks/status/<%= task._id %>" method="POST">

                <select
                    name="status"
                    class="form-select mb-3"
                >

                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Completed</option>

                </select>

                <button class="btn btn-primary w-100">
                    Update Status
                </button>

            </form>

        </div>

    </div>

<% }) %>

</div>

<%- include('partials/footer') %>