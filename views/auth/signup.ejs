<%- include('../partials/header') %>

<div class="row justify-content-center">

    <div class="col-md-5">

        <div class="custom-card">

            <h2 class="mb-4 text-center">
                Create Account
            </h2>

            <form action="/auth/signup" method="POST">

                <div class="mb-3">
                    <input
                        type="text"
                        name="name"
                        class="form-control"
                        placeholder="Enter Name"
                        required
                    >
                </div>

                <div class="mb-3">
                    <input
                        type="email"
                        name="email"
                        class="form-control"
                        placeholder="Enter Email"
                        required
                    >
                </div>

                <div class="mb-3">
                    <input
                        type="password"
                        name="password"
                        class="form-control"
                        placeholder="Enter Password"
                        required
                    >
                </div>

                <div class="mb-3">
                    <select name="role" class="form-select">

                        <option value="Member">
                            Member
                        </option>

                        <option value="Admin">
                            Admin
                        </option>

                    </select>
                </div>

                <button class="btn btn-primary w-100">
                    Signup
                </button>

            </form>

        </div>

    </div>

</div>

<%- include('../partials/footer') %>